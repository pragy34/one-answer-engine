{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    { "src": "main.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/start", "dest": "main.py" },
    { "src": "/answer", "dest": "main.py" },
    { "src": "/explain/(.*)", "dest": "main.py" },
    { "src": "/healthz", "dest": "main.py" },
    { "src": "/openapi.json", "dest": "main.py" },
    { "src": "/docs", "dest": "main.py" },
    { "src": "/docs/(.*)", "dest": "main.py" },

    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "frontend/dist/$1" }
  ]
}

